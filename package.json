{
  "name": "@next-design-labs/next-ui",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/next-design-labs/next-ui.git"
  },
  "license": "Apache-2.0",
  "author": "Next Design Labs team",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "doc": "pnpm -F {apps/docs} run dev",
    "storybook": "storybook dev -p 6006",
    "build": "pnpm -F {packages/**} run build",
    "build:doc": "pnpm -F {apps/docs} run build",
    "build:storybook": "storybook build",
    "check": "biome check --write --unsafe .",
    "typecheck": "pnpm -r --if-present run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "1.8.2",
    "@next-design-labs/next-ui-core": "workspace:*",
    "@next-design-labs/next-ui-styles": "workspace:*",
    "@next-design-labs/next-ui-uno-preset": "workspace:*",
    "@storybook/addon-controls": "^8.1.10",
    "@storybook/components": "^8.1.10",
    "@storybook/icons": "^1.2.9",
    "@storybook/manager-api": "^8.1.10",
    "@storybook/preview-api": "^8.1.10",
    "@storybook/react": "^8.1.10",
    "@storybook/react-vite": "^8.1.10",
    "@storybook/theming": "^8.1.10",
    "@types/node": "^20.14.7",
    "@unocss/reset": "^0.61.0",
    "@unocss/transformer-variant-group": "^0.61.0",
    "@vitejs/plugin-react": "^4.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.1.10",
    "typescript": "^5.5.2",
    "unocss": "^0.61.0",
    "vite": "^5.3.1",
    "vite-plugin-dts": "^3.9.1"
  },
  "packageManager": "pnpm@9.1.0"
}
